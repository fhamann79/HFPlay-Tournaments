@model Domain.SanctionMeliorate

@{
    ViewBag.Title = "BorrarSanción/Bonificación";
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>@Html.Raw(ViewBag.ErrorMessage)</strong>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<h2>Borrar</h2>

<h3>¿Está seguro de borrar esto?</h3>
<div>
    <h4>Sanción/Bonificación</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.TournamentTeam.TournamentGroup.Tournament.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.TournamentTeam.TournamentGroup.Tournament.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.TournamentTeam.TournamentGroup.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.TournamentTeam.TournamentGroup.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.TournamentTeam.Team.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.TournamentTeam.Team.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Value)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Value)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Type)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Type)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Description)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Description)
        </dd>

    </dl>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Borrar" class="btn btn-danger" /> |
            @Html.ActionLink("Regresar", "DetailsSanctionMeliorateTeam", new { id = Model.TournamentTeamId}, new { @class = "btn btn-success"})
        </div>
    }
</div>
