@model Domain.Date
@{
    ViewBag.Title = "Detalle";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@Html.Raw(TempData["SuccessMessage"].ToString())</strong>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>@Html.Raw(TempData["ErrorMessage"].ToString())</strong>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<h2>Torneo: @Model.Tournament.Name</h2>
<h3>Fecha: @Model.Name</h3>

<p>
    @Html.ActionLink("Crear Partido", "CreateMatch", new { id = Model.DateId }, new { @class = "btn btn-primary" })
    @Html.ActionLink("Regresar a Detalles de Torneo", "Details", new { id = Model.TournamentId }, new { @class = "btn btn-success" })
</p>
@if (Model.Matches.Count == 0)
{
    <h4>No se ha agregado partidos aún.</h4>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Matches.FirstOrDefault().DateTime)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Matches.FirstOrDefault().Stadium.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Matches.FirstOrDefault().Status.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Matches.FirstOrDefault().TournamentGroup.Name)
                </th>
                <th>
                    Local
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Matches.FirstOrDefault().LocalGoals)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Matches.FirstOrDefault().VisitorGoals)
                </th>
                <th>
                    Visitante
                </th>
                <th>
                    Acciones
                </th>
            </tr>
        </thead>
            @foreach (var item in Model.Matches.OrderBy(t => t.DateTime))
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.DateTimeEc) <span style="color:red">*</span>
                        
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Stadium.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Status.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.TournamentGroup.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Local.Name)
                        <br />
                        @if (!string.IsNullOrEmpty(item.Local.Logo))
                    {
                            <img src="@Url.Content(item.Local.Logo)" alt="Image" style="width:80px;height:80px;max-width: 100%; height: auto;" />
                        }
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.LocalGoals)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.VisitorGoals)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Visitor.Name)
                        <br />
                        @if (!string.IsNullOrEmpty(item.Visitor.Logo))
                    {
                            <img src="@Url.Content(item.Visitor.Logo)" alt="Image" style="width:80px;height:80px;max-width: 100%; height: auto;" />
                        }
                    </td>


                    <td>
                        @Html.ActionLink("Validar", "CloseMatchAdmin", new { id = item.MatchId }, new { @class = "btn btn-success" })
                        @Html.ActionLink("Editar", "EditMatch", new { id = item.MatchId }, new { @class = "btn btn-warning" })
                        @Html.ActionLink("Borrar", "DeleteMatch", new { id = item.MatchId }, new { @class = "btn btn-danger" })
                        @Html.ActionLink("Detalles", "DetailsMatch", new { id = item.MatchId }, new { @class = "btn btn-info" })
                    </td>
                </tr>
            }

    </table>
    <p><span style="color:red">*</span> Hora de Ecuador Continental</p>
}





