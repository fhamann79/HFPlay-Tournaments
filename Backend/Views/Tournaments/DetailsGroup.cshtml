@model Domain.TournamentGroup

@{
    ViewBag.Title = "Index";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@Html.Raw(TempData["SuccessMessage"].ToString())</strong>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<h2>Torneo: @Model.Tournament.Name</h2>
<h3>Grupo: @Model.Name</h3>

<p>
    @Html.ActionLink("Crear Equipo", "CreateTeam", new { id = Model.TournamentGroupId }, new { @class = "btn btn-primary" })
    @Html.ActionLink("Regresar a Detalles de Torneo", "Details", new { id = Model.TournamentId }, new { @class = "btn btn-success" })
</p>
@if (Model.TournamentTeams.Count == 0)
{
    <h4>No se ha agregado equipos aún.</h4>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>
                    POS.
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.TournamentTeams.FirstOrDefault().Team.Logo)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.TournamentTeams.FirstOrDefault().Team.Name)
                </th>
                <th>
                    PJ
                </th>
                <th>
                    PG
                </th>
                <th>
                    PP
                </th>
                <th>
                    PE
                </th>
                <th>
                    GF
                </th>
                <th>
                    GC
                </th>
                <th>
                    PTS.
                </th>
                <th>
                    GD
                </th>
                <th>
                    S/B
                </th>
                <th>
                    Acciones
                </th>
            </tr>
        </thead>
            @foreach (var item in Model.TournamentTeams.OrderBy(t => t.Position))
            {
                <tr>
                    <td>
                        <h5>@Html.DisplayFor(modelItem => item.Position)</h5>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Team.Logo))
                    {
                            <img src="@Url.Content(item.Team.Logo)" alt="Image" style="width:50px;height:50px;max-width: 100%; height: auto;" />
                        }
                    </td>
                    <td>
                        <h6>@Html.DisplayFor(modelItem => item.Team.Name)</h6>
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.MatchesPlayed)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.MatchesWon)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.MatchesLost)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.MatchesTied)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.FavorGoals)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.AgainstGoals)
                    </td>
                    <td>
                        <h5>@Html.DisplayFor(modelItem => item.Points)</h5>
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DifferenceGoals)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.SanctionMeliorates.Count)
                    </td>
                    <td>
                        @*@Html.ActionLink("Editar", "EditTeam", new { id = item.TournamentTeamId }, new { @class = "btn btn-warning" })*@
                        @Html.ActionLink("Detalles", "DetailsSanctionMeliorateTeam", new { id = item.TournamentTeamId }, new { @class = "btn btn-info" })
                        @Html.ActionLink("Borrar", "DeleteTeam", new { id = item.TournamentTeamId }, new { @class = "btn btn-danger" })
                    </td>
                </tr>
            }

    </table>
}



