@model IEnumerable<Domain.Tournament>

@{
    ViewBag.Title = "Index";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@Html.Raw(TempData["SuccessMessage"].ToString())</strong>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<h2>Torneos</h2>

<p>
    @Html.ActionLink("Crear Nuevo", "Create" , new { }, new { @class = "btn btn-primary"})
</p>
<table class="table table-bordered table-hover">
    <thead class="thead-light">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Logo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order)
            </th>
            <th>
                # Grupos
            </th>
            <th>
                # Fechas
            </th>
            <th>
                Acciones
            </th>
        </tr>
    </thead>
        @foreach (var item in Model.OrderBy(t => t.Order))
        {
            <tr>
                <td>

                    @Html.ActionLink(String.Format(item.Name), "Details", new { id = item.TournamentId }, new { })
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Logo))
                    {
                        <img src="@Url.Content(item.Logo)" alt="Image" style="width:100px;height:100px;max-width: 100%; height: auto;" />
                        @*<img src="@Url.Action("Thumbnail", "Generic", new { width = 100, height = 100 , path = item.Logo})" 
                             alt="thumb" style="width:100px;height:100px;max-width: 100%; height: auto;" />*@
                    }
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IsActive)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Order)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TournamentGroups.Count)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Dates.Count)
                </td>
                <td>
                    @Html.ActionLink("Editar", "Edit", new { id = item.TournamentId }, new { @class = "btn btn-warning" }) |
                    @Html.ActionLink("Detalles", "Details", new { id = item.TournamentId }, new { @class = "btn btn-info" }) |
                    @Html.ActionLink("Borrar", "Delete", new { id = item.TournamentId }, new { @class = "btn btn-danger" })
                </td>
            </tr>
        }

</table>


