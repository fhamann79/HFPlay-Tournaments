@model Domain.Tournament

@{
    ViewBag.Title = "Tablas de Posiciones y Calendarios";
}

<h2>Tablas de Posiciones y Calendarios</h2>
<p>
    @Html.ActionLink("Regresar", "Index", new { }, new { @class = "btn btn-success" })

</p>
<div>
    <h4>Torneo</h4>
    <h5>@Html.DisplayFor(model => model.Name)</h5>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <h5>Tablas de Posiciones por Grupos</h5>
            @if (Model.TournamentGroups.Count == 0)
            {
                <h5>No hay grupos registrados aún</h5>
            }
            else
            {
                <table class="table table-bordered table-hover">
                    <thead class="thead-light">
                        <tr>

                            <th>
                                @Html.DisplayNameFor(model => model.TournamentGroups.FirstOrDefault().Name)
                            </th>
                            <th>
                                # Equipos
                            </th>
                            <th>
                                Acciones
                            </th>
                        </tr>
                    </thead>
                    @foreach (var item in Model.TournamentGroups.OrderBy(g => g.Name))
                {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.TournamentTeams.Count)
                            </td>
                            <td>
                                
                                @Html.ActionLink("Ver tabla", "DetailsGroup", new { id = item.TournamentGroupId }, new { @class = "btn btn-info" }) 
                                
                            </td>
                        </tr>
                    }

                </table>
            }
        </div>

        <div class="col-md-6">
            <h5>Calendarios por Fechas</h5>
            @if (Model.Dates.Count == 0)
            {
                <h5>No hay fechas registradas aún</h5>
            }
            else
            {
                <table class="table table-bordered table-hover">
                    <thead class="thead-light">
                        <tr>

                            <th>
                                @Html.DisplayNameFor(model => model.Dates.FirstOrDefault().Name)
                            </th>
                            <th>
                                # Partidos
                            </th>
                            <th>
                                Acciones
                            </th>
                        </tr>
                    </thead>
                    @foreach (var item in Model.Dates.OrderBy(d => d.Name))
                {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Matches.Count)
                            </td>
                            <td>
                                
                                @Html.ActionLink("Ver calendario", "DetailsDate", new { id = item.DateId }, new { @class = "btn btn-info" }) 
                                
                            </td>
                        </tr>
                    }

                </table>
            }
        </div>
    </div>

    

        
</div>

