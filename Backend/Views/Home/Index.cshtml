                                                                <img src="@Url.Content(itemTte.Team.Logo)" alt="Image" style="width:25px;height:25px;max-width: 100%; height: auto;" />
                                                            }
                                                        </td>
                                                        <td>
                                                            <b>@Html.DisplayFor(modelItem => itemTte.Team.Name)</b>
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.MatchesPlayed)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.MatchesWon)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.MatchesLost)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.MatchesTied)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.FavorGoals)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.AgainstGoals)
                                                        </td>
                                                        <td>
                                                            <b>@Html.DisplayFor(modelItem => itemTte.Points)</b>
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => itemTte.DifferenceGoals)
                                                        </td>

                                                    </tr>
                                                }
                                            </table>

                                        </div>
                                        
                                        

                                    }
                                }
                                <br />
                                @if (item.Team.Locals.Where(l => l.DateTime > DateTime.UtcNow).ToList().Count == 0)
