                                    <img src="@Url.Content(item.Picture)" alt="Image" style="width:600px;height:600px;max-width: 100%; height: auto;" />
                                }

                            </p>
                        </div>
                    </div>
                    <hr />


                }

                @Html.PagedListPager(Model.NewItems, page => Url.Action("Index",
