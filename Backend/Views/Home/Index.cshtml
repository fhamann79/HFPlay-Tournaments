                                            <table>
                                                <thead class="thead-light">
                                                    <tr>
                                                        <th>
                                                            POS.
                                                        </th>
                                                        <th>
                                                            @Html.DisplayNameFor(model => model.TournamentTeams.FirstOrDefault().Team.Logo)
                                                        </th>
                                                        <th>
                                                            @Html.DisplayNameFor(model => model.TournamentTeams.FirstOrDefault().Team.Name)
                                                        </th>
                                                        <th>
                                                            PJ
                                                        </th>
                                                        <th>
                                                            PG
                                                        </th>
                                                        <th>
                                                            PP
                                                        </th>
                                                        <th>
                                                            PE
                                                        </th>
                                                        <th>
                                                            GF
                                                        </th>
                                                        <th>
                                                            GC
                                                        </th>
                                                        <th>
                                                            PTS.
                                                        </th>
                                                        <th>
                                                            GD
                                                        </th>

                                                    </tr>
                                                </thead>
                                                @foreach (var itemTte in Model.TournamentTeams
                                .Where(tt => tt.TournamentGroupId == itemTt.TournamentGroupId)
                                .OrderBy(tt => tt.Position))
                                                {
                                                    <tr>
                                                        <td>
                                                            <b>@Html.DisplayFor(modelItem => itemTte.Position)</b>
                                                        </td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(itemTte.Team.Logo))
