                                                        <img src="@Url.Content(itemMatchVisitors.Visitor.Logo)" alt="Image" style="width:50px;height:50px;max-width: 100%; height: auto;" />
                                                    }
                                                    <h6>@itemMatchVisitors.Visitor.Name</h6>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td align="center"></td>
                                                <td width="50px" align="center"></td>
                                                <td align="center"></td>
                                            </tr>
                                        </table>
                                        <br />
                                    }
                                }
                            </td>
                        </tr>
                    }
                </table>
            }

