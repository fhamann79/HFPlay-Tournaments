                                        <strong>Tu equipo no participa en torneo alguno.</strong>
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <h5>@Html.DisplayFor(modelItem => item.Team.Name) participa en:</h5>
                                    foreach (var itemTt in item.Team.TournamentTeams)
                                    {
                                        <br />
                                        if (!string.IsNullOrEmpty(itemTt.TournamentGroup.Tournament.Logo))
                                        {

                                            <img src="@Url.Content(itemTt.TournamentGroup.Tournament.Logo)" alt="Image" style="width:64px;height:64px;max-width: 100%; height: auto;" />


                                        }
                                        <br />

                                        <p><h6>@Html.DisplayFor(modelItem => itemTt.TournamentGroup.Tournament.Name)</h6></p>

                                        <p><b>Grupo: </b>@Html.DisplayFor(modelItem => itemTt.TournamentGroup.Name)</p>
