                                    </a>

                                }
                                <br />
                                <a href="@Url.Content(string.Format("~/Leagues/DetailsTeamPlayer/{0}",item.TeamId))">
                                    @Html.DisplayFor(modelItem => item.Team.Name)
                                </a>

                                <p><span>Camiseta número: </span>@Html.DisplayFor(modelItem => item.Number)</p>
                                <br />

                                @if (item.Team.TournamentTeams.Count == 0)
                                {
