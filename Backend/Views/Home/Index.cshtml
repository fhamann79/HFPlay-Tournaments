                                </div>

                                @if (!string.IsNullOrEmpty(item.Logo))
                                {
                                    <a href="@Url.Content(string.Format("~/Home/DetailsTournament/{0}",item.TournamentId))">
                                        <img src="@Url.Content(item.Logo)" alt="Image" class="card-img-top" />
                                    </a>

                                }

                                <div class="card-footer mx-auto">

                                    @Html.ActionLink("Detalles de Torneo", "DetailsTournament", new { id = item.TournamentId }, new { @class = "btn btn-info btn-lg" })

                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="col-md-4">
            <h3>Buzón Deportivo</h3>
            <hr />
            @if (Model.NewItems.Count() == 0)
                {
                <h5>No existen noticias aún.</h5>
            }
            else
            {
                using (Html.BeginForm("Index", "Home", FormMethod.Get, new { @class = "form-inline my-2 my-lg-0" }))
                {
                    <p>
                        @Html.TextBox("SearchString", ViewBag.CurrentFilter as string,
                            htmlAttributes: new { @class = "form-control mr-sm-2", placeholder = "Buscar" })
                        <button class="btn btn-outline-success my-2 my-sm-0" type="submit">Buscar</button>
                    </p>
                }

                @Html.PagedListPager(Model.NewItems, page => Url.Action("Index",
                new { page = page, currentFilter = ViewBag.CurrentFilter }),
                new PagedListRenderOptions
                {
                    DisplayLinkToIndividualPages = true,
                    DisplayPageCountAndCurrentLocation = true,
                    PageCountAndCurrentLocationFormat = "Página {0} de {1}",
                    DisplayItemSliceAndTotal = true,
                    ItemSliceAndTotalFormat = "Ítem {0} a {1} de {2}",
                })

                <hr />

                <script async src="//pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-format="fluid"
                     data-ad-layout-key="-81+1p-gq+ar+13k"
                     data-ad-client="ca-pub-4049042903887852"
                     data-ad-slot="3967951204"></ins>
                    <script>
                        (adsbygoogle = window.adsbygoogle || []).push({});
                    </script>
                    <hr />
                foreach (var item in Model.NewItems)
                {
                    <div class="panel panel-default">
                        <div class="panel-body">
                            <div class="row">
                                <div class="col-md-12">
                                    @if (!string.IsNullOrEmpty(item.User.Picture))
                                    {
                                        <img src="@Url.Content(item.User.Picture)" alt="Image" style="width:40px;height:40px;max-width: 100%; height: auto;" />
                                    }
                                    <a href="#"><b>@Html.DisplayFor(modelItem => item.User.NickName)</b> publicó el </a>
                                    <a href="#">@Html.DisplayFor(modelItem => item.PublicationDate)</a>
                                </div>

                            </div>
                            <br>
                            <h4>@Html.DisplayFor(modelItem => item.Title)</h4>
                            <p>
                                @Html.DisplayFor(modelItem => item.Content)
                                <br><br>
                                @if (!string.IsNullOrEmpty(item.Picture))
                                {
                                    <img src="@Url.Content(item.Picture)" alt="Image" style="width:600px;height:600px;max-width: 100%; height: auto;" />
                                }

                            </p>
                        </div>
                    </div>
                    <hr />


                }

                @Html.PagedListPager(Model.NewItems, page => Url.Action("Index",
                new { page = page, currentFilter = ViewBag.CurrentFilter }),
                new PagedListRenderOptions
                {
                    DisplayLinkToIndividualPages = true,
                    DisplayPageCountAndCurrentLocation = true,
                    PageCountAndCurrentLocationFormat = "Página {0} de {1}",
                    DisplayItemSliceAndTotal = true,
                    ItemSliceAndTotalFormat = "Ítem {0} a {1} de {2}",
                })
            }
        </div>
        <div class="col-md-2">
            <h3>Anuncios</h3>
            <hr />
            <script async src="//pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-format="fluid"
                 data-ad-layout-key="+3i+q4+4e-md+ol"
                 data-ad-client="ca-pub-4049042903887852"
                 data-ad-slot="6430003489"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </div>
    </div>
}







