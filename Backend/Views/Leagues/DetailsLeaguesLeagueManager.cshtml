@model Domain.League

@{
    ViewBag.Title = "Detalles";
}

<h2>Detalles - Dirigente de Liga</h2>

<div>
    <h4>Liga</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Logo)
        </dt>

        <dd>
            @if (!string.IsNullOrEmpty(Model.Logo))
            {
                <img src="@Url.Content(Model.Logo)" alt="Image" style="width:100px;height:100px;max-width: 100%; height: auto;" />
            }
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Regresar", "IndexLeaguesLeagueManager", new { }, new { @class = "btn btn-success" })
    @Html.ActionLink("Configurar Carnets", "SetupCardLeagueLeagueManager", new { id = Model.LeagueId }, new { @class = "btn btn-success" })
</p>
<h4>Equipos</h4>
@if (Model.Teams.Count == 0)
{
    <h5>No hay equipos registrados aún o no eres dirigente de ésta liga.</h5>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Teams.FirstOrDefault().Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Teams.FirstOrDefault().Logo)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Teams.FirstOrDefault().Initials)
                </th>
                <th>
                    # Jugadores
                </th>
                <th>
                    Acciones
                </th>
            </tr>
        </thead>


        @foreach (var item in Model.Teams.OrderBy(t => t.Name))
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Logo))
                    {
                        <img src="@Url.Content(item.Logo)" alt="Image" style="width:100px;height:100px;max-width: 100%; height: auto;" />
                    }
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Initials)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TeamPlayers.Count)
                </td>
                <td>

                    @Html.ActionLink("Detalles", "DetailsTeamLeagueManager", new { id = item.TeamId }, new { @class = "btn btn-info" }) |

                </td>
            </tr>
        }

    </table>
}