@model Domain.LeagueCredentialLogo

@{
    ViewBag.Title = "Borrar";
}

<h2>Borrar</h2>

<h3>¿Está seguro desea borrar esto?</h3>
<div>
    <h4>Logo de Carnet de Liga</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.League.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.League.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Description)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Description)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.LeagueMainLogo)
        </dt>

        <dd>
            @if (!string.IsNullOrEmpty(Model.LeagueMainLogo))
            {
                <img src="@Url.Content(Model.LeagueMainLogo)" alt="Image" style="width:150px;height:150px;max-width: 100%; height: auto;" />
            }
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.FrontSecondaryLogo)
        </dt>

        <dd>
            @if (!string.IsNullOrEmpty(Model.FrontSecondaryLogo))
            {
                <img src="@Url.Content(Model.FrontSecondaryLogo)" alt="Image" style="width:150px;height:150px;max-width: 100%; height: auto;" />
            }
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.ReverseMainLogo)
        </dt>

        <dd>
            @if (!string.IsNullOrEmpty(Model.ReverseMainLogo))
            {
                <img src="@Url.Content(Model.ReverseMainLogo)" alt="Image" style="width:150px;height:150px;max-width: 100%; height: auto;" />
            }
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.ReverseSecondaryLogo)
        </dt>

        <dd>
            @if (!string.IsNullOrEmpty(Model.ReverseSecondaryLogo))
            {
                <img src="@Url.Content(Model.ReverseSecondaryLogo)" alt="Image" style="width:150px;height:150px;max-width: 100%; height: auto;" />
            }
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.MainReverseText)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.MainReverseText)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.SecondaryReverseText)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.SecondaryReverseText)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.AlternateReverseText)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.AlternateReverseText)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.IsDefault)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.IsDefault)
        </dd>

    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Borrar" class="btn btn-danger" /> |
            @Html.ActionLink("Regresar", "SetupCardLeagueLeagueManager", new { id = Model.LeagueId }, new { @class = "btn btn-success" })
        </div>

    }
</div>

