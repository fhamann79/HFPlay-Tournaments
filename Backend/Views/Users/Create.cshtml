            </div>
        </div>
        
        <div class="form-group">
            @Html.LabelFor(model => model.PhotoFile, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <span class="btn btn-default btn-file">
                    @Html.TextBoxFor(modelo => modelo.PhotoFile, new { type = "file" })
                </span>
            </div>
        </div>
        
        <div class="form-group">
            @Html.LabelFor(model => model.FavoriteLeagueId, "Liga Favorita", htmlAttributes: new { @class = "control-label col-md-2" })
