@model IEnumerable<Domain.User>

@{
    ViewBag.Title = "Gestionar";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>@Html.Raw(TempData["SuccessMessage"].ToString())</strong>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}


<h2>Gestionar Usuario</h2>

<p>
    @Html.ActionLink("Cambiar Contraseña", "ForgotPassword","Account", new { title = "Cambiar Contraseña" }, new { @class = "btn btn-danger" })
</p>

<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.FavoriteTeam.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.UserType.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FirstName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.LastName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Email)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.NickName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Picture)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Points)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @if (!string.IsNullOrEmpty(item.FavoriteTeam.Logo))
                {
                    <img src="@Url.Content(item.FavoriteTeam.Logo)" alt="Image" style="width:100px;height:100px;max-width: 100%; height: auto;" />
                }

            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UserType.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NickName)
            </td>
            <td>
                @if (!string.IsNullOrEmpty(item.Picture))
                {
                    <img src="@Url.Content(item.Picture)" alt="Image" style="width:100px;height:100px;max-width: 100%; height: auto;" />
                }

            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Points)
            </td>
            <td>
                @Html.ActionLink("Editar", "EditManageUser", new { id = item.UserId }, new { @class = "btn btn-warning"}) @*|
                @Html.ActionLink("Detalles", "Details", new { id = item.UserId }) |
                @Html.ActionLink("Borrar", "Delete", new { id = item.UserId })*@
            </td>
        </tr>
    }

</table>
